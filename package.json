{
  "name": "chess-app",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "pages:build": "npm run build && npx @cloudflare/next-on-pages --skip-build",
    "pages:dev": "npx wrangler pages dev .vercel/output/static --compatibility-date=2024-01-01",
    "pages:deploy": "npm run pages:build && npx wrangler pages deploy .vercel/output/static"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@supabase/supabase-js": "^2.87.1",
    "@types/dompurify": "^3.0.5",
    "chess.js": "^1.4.0",
    "clsx": "^2.1.1",
    "country-flag-icons": "^1.6.4",
    "dompurify": "^3.3.1",
    "dotenv": "^17.2.3",
    "framer-motion": "^12.23.25",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.555.0",
    "next": "^16.1.6",
    "next-mdx-remote": "^6.0.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "recharts": "^3.5.1",
    "resend": "^6.6.0",
    "stockfish": "^17.1.0",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.13.16",
